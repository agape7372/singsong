{
  "name": "singsong-session-strip",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first karaoke session planner and shareable ticket PWA",
  "license": "UNLICENSED",
  "engines": {
    "node": "24.18.0",
    "pnpm": "11.9.0"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "pnpm run dev:demo",
    "dev:demo": "cross-env APP_PROFILE=fixture NEXT_PUBLIC_APP_PROFILE=fixture next dev --webpack",
    "dev:fixture": "pnpm run dev:demo",
    "build": "pnpm run build:demo",
    "build:demo": "cross-env APP_PROFILE=fixture NEXT_PUBLIC_APP_PROFILE=fixture next build --webpack",
    "build:fixture": "pnpm run build:demo",
    "preflight:release": "cross-env APP_PROFILE=release NEXT_PUBLIC_APP_PROFILE=release node scripts/release-preflight.mjs",
    "verify:release-artifact": "node scripts/verify-release-artifact.mjs",
    "build:release": "pnpm run preflight:release && cross-env APP_PROFILE=release NEXT_PUBLIC_APP_PROFILE=release next build --webpack && pnpm run verify:release-artifact",
    "build:production": "pnpm run build:release",
    "start": "next start",
    "install:frozen": "cross-env CI=1 pnpm install --frozen-lockfile",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:contract": "vitest run tests/static tests/unit/canonical.test.ts tests/unit/validation.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:pwa": "playwright test --config playwright.production.config.ts",
    "test:pwa:release": "cross-env APP_PROFILE=production NEXT_PUBLIC_APP_PROFILE=production playwright test --config playwright.production.config.ts",
    "smoke:http": "node scripts/smoke-http.mjs",
    "perf:lab": "node scripts/perf-lab.mjs",
    "verify": "pnpm run verify:demo",
    "verify:demo": "pnpm run install:frozen && pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build:demo && node scripts/verify-built-pwa.mjs && cross-env APP_PROFILE=fixture NEXT_PUBLIC_APP_PROFILE=fixture node scripts/smoke-http.mjs && pnpm test:e2e && pnpm test:pwa",
    "verify:release": "pnpm run install:frozen && pnpm run preflight:release && pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build:release && node scripts/verify-built-pwa.mjs && cross-env APP_PROFILE=production NEXT_PUBLIC_APP_PROFILE=production node scripts/smoke-http.mjs && pnpm run test:pwa:release",
    "verify:production": "pnpm run verify:release",
    "icons": "node scripts/generate-icons.mjs",
    "clean:generated": "node scripts/clean-generated.mjs"
  },
  "dependencies": {
    "@base-ui/react": "1.6.0",
    "@serwist/next": "9.5.11",
    "@supabase/supabase-js": "2.110.7",
    "dexie": "4.4.4",
    "html-to-image": "1.11.13",
    "motion": "12.42.2",
    "next": "16.2.11",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "0.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.3",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.10",
    "cross-env": "10.1.0",
    "eslint": "9.39.1",
    "eslint-config-next": "16.2.11",
    "fake-indexeddb": "6.2.5",
    "fast-check": "4.9.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "serwist": "9.5.11",
    "sharp": "0.34.5",
    "tailwindcss": "4.3.3",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
