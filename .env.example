# Required explicit runtime profile: fixture for local demo, release for a real deployment.
APP_PROFILE=fixture
NEXT_PUBLIC_APP_PROFILE=fixture
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Emergency kill switch. Set false to unregister /sw.js and delete only singsong-* caches.
NEXT_PUBLIC_PWA_ENABLED=true

# Production-only server values. Keep blank in this example and never prefix them NEXT_PUBLIC_.
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SHARE_SLUG_HMAC_KEY_V1=
SHARE_SLUG_ACTIVE_KEY_VERSION=1
RATE_LIMIT_IP_HMAC_KEY_V1=
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_ALLOWED_HOSTNAMES=

# Release-only licensed catalog gate. The manifest is an external, reviewed JSON
# evidence record; do not put confidential contracts or credentials in it.
# Its SHA-256 is the lowercase/uppercase 64-character hex digest of the exact file.
CATALOG_RIGHTS_MANIFEST_PATH=
CATALOG_RIGHTS_MANIFEST_SHA256=
CATALOG_PROVIDER_URL=
CATALOG_PROVIDER_API_KEY=
# Deployed HTTPS origin used only by verify:release browser/PWA checks.
RELEASE_BASE_URL=

# Optional production operations integrations. Values must remain server-only.
RATE_LIMIT_REDIS_URL=
RATE_LIMIT_REDIS_TOKEN=
OBSERVABILITY_DSN=
